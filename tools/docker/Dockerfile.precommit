FROM golang:1.24

# Allow pip install without --break-system-packages inside the container.
# Needed because make targets (e.g. agent-bootstrap) call pip directly.
ENV PIP_BREAK_SYSTEM_PACKAGES=1

# System dependencies — matches CI "Install system dependencies" step.
# shellcheck is the native apt binary (CI does NOT use shellcheck-py).
RUN apt-get update && apt-get install -y \
    make \
    build-essential \
    pkg-config \
    shellcheck \
    python3 \
    python3-pip \
    python3-venv \
    libssl-dev \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Node.js 20 — matches CI setup-node node-version: 20
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y nodejs

# Rust 1.90 with rustfmt + clippy — matches CI dtolnay/rust-toolchain 1.90
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain 1.90.0
ENV PATH="/root/.cargo/bin:${PATH}"
RUN rustup component add rustfmt clippy

# markdownlint-cli pinned — matches agent-bootstrap npm install
RUN npm install -g markdownlint-cli@0.43.0

# Python tooling — versions match tools/agent/requirements.txt so that
# `make agent-ci-lint` and `make precommit-check` both work out of the box.
RUN pip install --break-system-packages \
    PyYAML==6.0.3 \
    codespell==2.4.1 \
    pre-commit==4.3.0 \
    ruff==0.15.5 \
    tree-sitter==0.25.2 \
    tree-sitter-go==0.25.0 \
    tree-sitter-javascript==0.25.0 \
    tree-sitter-python==0.25.0 \
    tree-sitter-rust==0.24.0 \
    tree-sitter-typescript==0.23.2 \
    yamllint==1.38.0

# Golangci-lint v2.5.0 — matches CI golangci-lint-action version
RUN curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/HEAD/install.sh | sh -s -- -b $(go env GOPATH)/bin v2.5.0
