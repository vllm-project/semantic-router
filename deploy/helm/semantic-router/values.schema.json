{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "semantic-router Helm values",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of Semantic Router pod replicas when autoscaling is disabled."
    },
    "runtimeCredentials": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "generation": {
          "type": "string",
          "description": "Opaque CLI-managed runtime credential generation identifier."
        },
        "recreateForLooperRotation": {
          "type": "boolean",
          "description": "Request a Recreate rollout strategy for CLI-managed runtime credential revisions."
        }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "minReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "maxReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "targetCPUUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "targetMemoryUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "storageClassName": {
          "type": "string"
        }
      }
    },
    "safetyGuards": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "rejectMultiReplicaLocalLearningState": {
          "type": "boolean",
          "description": "Reject multi-replica router renders when active config enables Router Learning request-time local state."
        }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "alerts": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Render PrometheusRule alerts for Semantic Router metrics."
            },
            "labels": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "thresholds": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "requestErrorRate": {
                  "type": "number",
                  "minimum": 0
                },
                "completionLatencyP95Seconds": {
                  "type": "number",
                  "minimum": 0
                },
                "ttftP95Seconds": {
                  "type": "number",
                  "minimum": 0
                },
                "tpotP95Seconds": {
                  "type": "number",
                  "minimum": 0
                },
                "routingLatencyP95Seconds": {
                  "type": "number",
                  "minimum": 0
                },
                "inflightRequests": {
                  "type": "number",
                  "minimum": 0
                },
                "cacheHitRate": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          }
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "routing": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "decisions": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "algorithm": {
                    "type": "object",
                    "additionalProperties": true,
                    "properties": {
                      "type": {
                        "type": "string"
                      },
                      "storage_path": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "dashboard": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "allowOpenBootstrap": {
          "type": "boolean"
        },
        "replicaCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        },
        "persistence": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "existingClaim": {
              "type": "string"
            },
            "storageClassName": {
              "type": "string"
            },
            "accessMode": {
              "type": "string"
            },
            "size": {
              "type": "string"
            },
            "mountPath": {
              "type": "string"
            }
          }
        },
        "podSecurityContext": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "fsGroup": {
              "type": "integer"
            }
          }
        },
        "jwtSecret": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "existingSecret": {
              "type": "string"
            },
            "existingSecretKey": {
              "type": "string"
            }
          }
        },
        "passwordBlocklist": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "existingConfigMap"
          ],
          "properties": {
            "existingConfigMap": {
              "type": "string",
              "maxLength": 253,
              "pattern": "^$|^[a-z0-9]([-a-z0-9]*[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*$"
            },
            "key": {
              "type": "string",
              "minLength": 1,
              "maxLength": 253,
              "pattern": "^[A-Za-z0-9._-]+$"
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "existingConfigMap": {
                    "minLength": 1
                  }
                },
                "required": [
                  "existingConfigMap"
                ]
              },
              "then": {
                "properties": {
                  "key": {
                    "minLength": 1
                  }
                },
                "required": [
                  "key"
                ]
              }
            }
          ]
        },
        "extraEnv": {
          "type": "array"
        },
        "envFrom": {
          "type": "array"
        }
      }
    }
  }
}
