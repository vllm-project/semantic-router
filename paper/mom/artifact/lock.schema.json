{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vllm.ai/schemas/mom/lock-v0alpha1.json",
  "title": "Mixture-of-Models resolution lock",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "subject",
    "bindingDigest",
    "realizationProfile",
    "resolvedAt",
    "controlEngine",
    "targets"
  ],
  "properties": {
    "schemaVersion": {"const": "mom.vllm.ai/lock/v0alpha1"},
    "subject": {"$ref": "#/$defs/subject"},
    "bindingDigest": {"$ref": "#/$defs/digest"},
    "realizationProfile": {"$ref": "#/$defs/name"},
    "resolvedAt": {"type": "string", "format": "date-time"},
    "controlEngine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "revision",
        "imageDigest",
        "supportedOpsets",
        "supportedCapabilities",
        "resolver"
      ],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "revision": {"type": "string", "minLength": 1},
        "imageDigest": {"$ref": "#/$defs/digest"},
        "supportedOpsets": {"$ref": "#/$defs/stringSet"},
        "supportedCapabilities": {"$ref": "#/$defs/stringSet"},
        "resolver": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": {"type": "string", "minLength": 1},
            "version": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "realizedConfig": {"$ref": "#/$defs/descriptor"},
    "targets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidates"],
        "properties": {
          "candidates": {
            "type": "array",
            "minItems": 1,
            "items": {"$ref": "#/$defs/candidate"}
          }
        }
      }
    }
  },
  "$defs": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9._-]*$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "stringSet": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "modelId",
        "modelVersion",
        "behaviorVariant",
        "semanticDigest",
        "bundleDigest"
      ],
      "properties": {
        "modelId": {"type": "string", "minLength": 1},
        "modelVersion": {"type": "string", "minLength": 1},
        "behaviorVariant": {"$ref": "#/$defs/name"},
        "semanticDigest": {"$ref": "#/$defs/digest"},
        "bundleDigest": {"$ref": "#/$defs/digest"}
      }
    },
    "descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "mediaType", "digest", "size"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "mediaType": {"type": "string", "minLength": 1},
        "digest": {"$ref": "#/$defs/digest"},
        "size": {"type": "integer", "minimum": 0}
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bindingId",
        "wireTransport",
        "apiAdapter",
        "artifact",
        "runtime",
        "deploymentDriver",
        "capabilityEvidence"
      ],
      "properties": {
        "bindingId": {"$ref": "#/$defs/name"},
        "wireTransport": {
          "type": "object",
          "additionalProperties": false,
          "required": ["protocol"],
          "properties": {
            "protocol": {"enum": ["http", "https", "grpc", "in-process"]}
          }
        },
        "apiAdapter": {
          "type": "object",
          "additionalProperties": false,
          "required": ["family", "interface", "externalModelId"],
          "properties": {
            "family": {"type": "string", "minLength": 1},
            "interface": {"type": "string", "minLength": 1},
            "externalModelId": {"type": "string", "minLength": 1},
            "apiVersion": {"type": "string", "minLength": 1},
            "operationPath": {"type": "string", "minLength": 1}
          }
        },
        "artifact": {
          "type": "object",
          "additionalProperties": false,
          "required": ["uri", "format", "identityStrength"],
          "properties": {
            "uri": {"type": "string", "minLength": 1},
            "format": {"type": "string", "minLength": 1},
            "identityStrength": {
              "enum": [
                "content-addressed",
                "repository-revision",
                "provider-version",
                "observed-opaque"
              ]
            },
            "revision": {"type": "string", "minLength": 1},
            "observedAlias": {"type": "string", "minLength": 1},
            "observedAt": {"type": "string", "format": "date-time"}
          }
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version"],
          "properties": {
            "name": {"type": "string", "minLength": 1},
            "version": {"type": "string", "minLength": 1},
            "imageDigest": {"$ref": "#/$defs/digest"}
          }
        },
        "accelerator": {
          "type": "object",
          "additionalProperties": false,
          "required": ["api", "version", "vendor", "architecture"],
          "properties": {
            "api": {"type": "string", "minLength": 1},
            "version": {"type": "string", "minLength": 1},
            "vendor": {"type": "string", "minLength": 1},
            "architecture": {"type": "string", "minLength": 1}
          }
        },
        "deploymentDriver": {"type": "string", "minLength": 1},
        "tokenizerDigest": {"$ref": "#/$defs/digest"},
        "adapterDigests": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/digest"}
        },
        "protocolAdapterDigest": {"$ref": "#/$defs/digest"},
        "pluginDigests": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/digest"}
        },
        "capabilityEvidence": {"$ref": "#/$defs/descriptor"}
      }
    }
  }
}
