{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vllm.ai/schemas/mom/eval-attestation-v0alpha1.json",
  "title": "Mixture-of-Models evaluation attestation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "subject",
    "suite",
    "execution",
    "metrics",
    "claimBoundary"
  ],
  "properties": {
    "schemaVersion": {"const": "mom.vllm.ai/eval-attestation/v0alpha1"},
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "modelId",
        "modelVersion",
        "behaviorVariant",
        "semanticDigest",
        "bundleDigest",
        "bindingDigest",
        "lockDigest"
      ],
      "properties": {
        "modelId": {"type": "string", "minLength": 1},
        "modelVersion": {"type": "string", "minLength": 1},
        "behaviorVariant": {"type": "string", "minLength": 1},
        "semanticDigest": {"$ref": "#/$defs/digest"},
        "bundleDigest": {"$ref": "#/$defs/digest"},
        "bindingDigest": {"$ref": "#/$defs/digest"},
        "lockDigest": {"$ref": "#/$defs/digest"}
      }
    },
    "suite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolDigest", "datasets", "harnessDigest"],
      "properties": {
        "protocolDigest": {"$ref": "#/$defs/digest"},
        "datasets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["taskId", "datasetDigest"],
            "properties": {
              "taskId": {"type": "string", "minLength": 1},
              "datasetDigest": {"$ref": "#/$defs/digest"}
            }
          }
        },
        "harnessDigest": {"$ref": "#/$defs/digest"}
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seed", "concurrency", "temperature", "sampling"],
      "properties": {
        "seed": {"type": "integer", "minimum": 0},
        "concurrency": {"type": "integer", "minimum": 1},
        "temperature": {"type": "number", "minimum": 0},
        "sampling": {"type": "string", "minLength": 1}
      }
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["taskId", "name", "value", "n"],
        "properties": {
          "taskId": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "value": {"type": "number"},
          "n": {"type": "integer", "minimum": 1},
          "confidenceInterval": {
            "type": "array",
            "prefixItems": [{"type": "number"}, {"type": "number"}],
            "minItems": 2,
            "maxItems": 2
          }
        }
      }
    },
    "rawResults": {"$ref": "#/$defs/descriptor"},
    "claimBoundary": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uri", "mediaType", "digest", "size"],
      "properties": {
        "uri": {"type": "string", "minLength": 1},
        "mediaType": {"type": "string", "minLength": 1},
        "digest": {"$ref": "#/$defs/digest"},
        "size": {"type": "integer", "minimum": 0}
      }
    }
  }
}
