# Dockerfile for building and running onnx-binding with AMD ROCm + MIGraphX support.

FROM rocm/dev-ubuntu-22.04:7.0

ARG ORT_ROCM_VERSION=1.22.1
ARG ORT_WHEEL_URL=https://repo.radeon.com/rocm/manylinux/rocm-rel-7.0/onnxruntime_rocm-1.22.1-cp310-cp310-manylinux_2_27_x86_64.manylinux_2_28_x86_64.whl

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        ca-certificates curl hipblas hipfft migraphx miopen-hip python3-pip rccl && \
    rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install --no-cache-dir "${ORT_WHEEL_URL}" && \
    ORT_DIR="$(python3 -c 'import pathlib, onnxruntime; print(pathlib.Path(onnxruntime.__file__).parent / "capi")')" && \
    mkdir -p /opt/onnxruntime && \
    ln -sfn "${ORT_DIR}" /opt/onnxruntime/capi && \
    ln -sf "/opt/onnxruntime/capi/libonnxruntime.so.${ORT_ROCM_VERSION}" /opt/onnxruntime/capi/libonnxruntime.so.1 && \
    ln -sf "/opt/onnxruntime/capi/libonnxruntime.so.${ORT_ROCM_VERSION}" /opt/onnxruntime/capi/libonnxruntime.so

# Install Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:/opt/rocm/bin:${PATH}"

# Set ORT library paths for dynamic loading
ENV ORT_DYLIB_PATH=/opt/onnxruntime/capi/libonnxruntime.so.1
ENV LD_LIBRARY_PATH=/opt/onnxruntime/capi:/opt/rocm/lib:${LD_LIBRARY_PATH}

WORKDIR /workspace

# Copy only Cargo files first for dependency caching
COPY Cargo.toml Cargo.lock* ./
RUN mkdir -p src && echo "fn main() {}" > src/main.rs && \
    cargo fetch || true && \
    rm -rf src

# Copy source code
COPY . .

# Build with dynamic ORT loading (uses container's MIGraphX-enabled ORT)
RUN cargo build --release --features migraphx-dynamic --examples

# Default command runs the benchmark
CMD ["./target/release/examples/benchmark_mmbert_latency"]
